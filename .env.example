# Patchouli keys. Copy this file to .env and fill in what you need.
# .env is gitignored; never commit real keys.
#
# A key may appear on multiple lines — the scripts pick one at random and retry
# across the rest on 401/403/429/5xx, so listing several keys gives you automatic
# load spreading and single-key failure tolerance with no shared state.

# Firecrawl — used by `ingest` to extract arbitrary web (HTML) pages.
# Arxiv and local-file ingest do not use it. Get keys at https://firecrawl.dev .
FIRECRAWL_API_KEY=
FIRECRAWL_API_KEY=

# Exa — used by `search` to discover candidate sources for a loose direction.
# Not used by ingest. Get keys at https://exa.ai .
EXA_API_KEY=
EXA_API_KEY=
